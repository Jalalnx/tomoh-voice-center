# Copy to .env.local for local development
# In dev, use the Vite proxy (points to localhost:8000 via the proxy config)
VITE_API_URL=/api/v1

# In production (CI build), set this to the actual backend URL:
# VITE_API_URL=https://app.tomoh.io/api/v1

# Optional: Platform URL for login redirects
# VITE_PLATFORM_URL=https://tomoh.io
