# Voice center API base — all voice form submissions go here.
# Dev: use the Vite proxy so you don't need CORS setup locally.
#   VITE_API_URL=/api/v1      ← put this in .env.local, NOT here
# Prod: set via GitHub secret VITE_API_URL.
VITE_API_URL=https://app.tomoh.io/api/v1

# Platform auth base — always app.tomoh.io regardless of VITE_API_URL.
# The feedback.tomoh.io nginx has no /api proxy so the auth probe must hit
# the platform directly. Override in .env.local for local dev:
#   VITE_PLATFORM_API_URL=/api/v1
VITE_PLATFORM_API_URL=https://app.tomoh.io/api/v1

# Platform root for login redirects
VITE_PLATFORM_URL=https://tomoh.io
